modules = ["nodejs-22", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "node_modules", ".next"]

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "autoscale"
build = "npm ci && npm run build"
# Shell-string run with explicit PORT. Replit's autoscale validator
# rejects the array form for Next.js server apps with a misleading
# "static site / no run command" error; shell form + PORT env passes.
run = "PORT=5000 npm run start"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
